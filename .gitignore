# Root .gitignore - general

# Python
myenv/
venv/
ENV/
env/
__pycache__/
*.py[cod]
*$py.class

# Virtual environment files
pip-log.txt
pip-delete-this-directory.txt

# Environments and secrets
.env
.env.*
.env.local

# VS Code
.vscode/

# OS files
.DS_Store
Thumbs.db

# Node / JS
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build outputs
dist/
build/
out/
/.parcel-cache/
.cache/

# Logs
logs/
*.log

# IDE
.idea/

# Misc
*.sqlite3

# Render-specific (not needed for Hugging Face Spaces)
render.yaml
.render-build/

# Old backups
backend/README_OLD.md
backend/app/services/*.backup
*.db
*.md