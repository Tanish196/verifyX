# Copy this file to .env and fill in the values. Do NOT commit your .env file.

# Google Fact Check API key
FACT_CHECK_API_KEY=your_google_fact_check_api_key_here

# Feature toggles
ENABLE_TRANSFORMERS=true
ENABLE_TORCH=true

# CORS settings (comma separated)
CORS_ORIGINS=*

# Limits
MAX_TEXT_LENGTH=10000
MAX_IMAGES=10

# Cache dir
CACHE_DIR=~/.cache/verifyx